# ===== Loop environment configuration =====
# Copy to .env.local for development. In production set these in your host's env.
# The app FAILS FAST if the required Supabase vars are missing (no silent fallback).

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key
# Service-role key — SERVER ONLY, never exposed to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (required for payments) ---
# Use sk_live_... in production, sk_test_... in development.
STRIPE_SECRET_KEY=sk_test_...
# From the Stripe dashboard webhook endpoint (whsec_...). Required for the webhook.
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (Resend) ---
RESEND_API_KEY=
# IMPORTANT: the default onboarding@resend.dev can ONLY email the Resend account
# owner. To deliver to arbitrary inboxes (brands, creators, the payouts inbox),
# verify a domain at resend.com/domains and set EMAIL_FROM to an address on it,
# e.g. EMAIL_FROM="Loop <noreply@yourdomain.com>".
EMAIL_FROM=Loop <onboarding@resend.dev>
EMAIL_REPLY_TO=
# Inbox that receives creator withdrawal requests to review/approve & pay out.
PAYOUTS_NOTIFY_EMAIL=loop.marketplace.ugc@gmail.com

# --- AI assistant (optional — falls back to a built-in mock if unset) ---
ANTHROPIC_API_KEY=

# --- Dev only ---
# Simulates successful payments with NO real Stripe charge. IGNORED in production
# (gated to NODE_ENV !== "production"). Leave unset/false for any real deploy.
NEXT_PUBLIC_DEV_PAYMENTS=false
